{
  "name": "bdsm-boundary-test",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build && vite build --ssr src/entry-server.ts --outDir dist-ssr && node scripts/prerender-seo.mjs",
    "build:functions": "npm --prefix functions run build",
    "test": "vitest run",
    "test:all": "npm run test && npm run test:rules && npm --prefix functions run test",
    "test:functions": "npm --prefix functions run test",
    "test:rules": "npx --yes firebase-tools@15.23.0 emulators:exec --only firestore --project demo-boundary-notes \"vitest run --config vitest.rules.config.ts\"",
    "test:watch": "vitest",
    "preview": "vite preview",
    "preview:hosting": "node scripts/preview-hosting.mjs"
  },
  "dependencies": {
    "firebase": "12.16.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "vue": "^3.5.17",
    "vue-router": "^4.6.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/server-renderer": "^3.5.17",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.2.12"
  }
}
