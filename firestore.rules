rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // App Check is enforced for Cloud Firestore at the project level. A share
    // ID is an unguessable bearer capability: clients may fetch that one public
    // snapshot, but may never enumerate the collection or mutate any document.
    match /sharedSecretFiles/{shareId} {
      allow get: if shareId.matches('^sf_[A-Za-z0-9_-]{24}$');
      allow list: if false;
      allow create, update, delete: if false;
    }

    // Uploads and all private anti-abuse data remain callable-only. The Admin
    // SDK bypasses these rules and is constrained by the Function service account.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
